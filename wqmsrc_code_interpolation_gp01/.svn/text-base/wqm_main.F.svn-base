                      !                  !Jcin/1000.0*2.667,                          &   !'Jcin'                mgC/m^2/d          
                      !                  !Jnin/1000.0,                                &  !'Jnin'                *mgN/m^2/d          
                      !                  !Jpin/1000.0,                                &  !'Jpin'                *mgP/m^2/d          
                      !             JPOC_GL(NstationNum_GL(I),1)/1000.0*2.667,    &      !'Jcin1'               mgC/m^2/d           
                      !                  JPOC_GL(NstationNum_GL(I),2)/1000.0*2.667,    &      !'Jcin2'               mgC/m^2/d      
                      !                  JPOC_GL(NstationNum_GL(I),3)/1000.0*2.667,    &      !'Jcin3'               mgC/m^2/d      
                      !                  JPON_GL(NstationNum_GL(I),1)/1000.0,         &      !'Jnin1'               *mgN/m^2/d      
                      !                  JPON_GL(NstationNum_GL(I),2)/1000.0,         &      !'Jnin2'               *mgN/m^2/d      
                      !                  JPON_GL(NstationNum_GL(I),3)/1000.0,         &      !'Jnin3'               *mgN/m^2/d      
