           !
           !!(O20_GL(MGL));            !given by C2_GL(:,:,27)
           !!(D_GL(MGL));                !already defined
           !(CTEMP_GL(MGL));             !
           !
               Call GATHER (1, MTLOC, MLOC, MGL, 1, MYID, NPROCS, NMAP, &
