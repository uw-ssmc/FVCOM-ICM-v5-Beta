     !               ATMFLXPB = ATMFLXPB / ELTMMBL
     !               BENFLXPNB = BENFLXPNB / ELTMMBL
     !               BENFLXDNB = BENFLXDNB / ELTMMBL
     !               BENFLXPPB = BENFLXPPB / ELTMMBL
