                      !                  C2_GL(NstationNum_GL(I),KBM1,14),            &        !'NO30'                *gN/m^3       
                      !                  C2_GL(NstationNum_GL(I),KBM1,20),            &        !'PO40'                *gP/m^3       
                      !                  C2_GL(NstationNum_GL(I),KBM1,29),            &        !'SI0'                *gSi/m^3       
                      !                  CH40_GL(NstationNum_GL(I)),                 &        !'CH40'             gO2/m^3           
