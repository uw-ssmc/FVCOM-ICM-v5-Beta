           !all of the following are used for outputing sediment flux variables into history and station files
           !Make sure all of them are collected
           !
           !(JPOC_GL(MGL,3));
           !(JPON_GL(MGL,3));
           !(JPOP_GL(MGL,3));
           !(JPOS_GL(MGL));
           !
