               Call GATHER (1, MTLOC, MLOC, MGL, KBM1, MYID, NPROCS, &
              & NMAP, FI2(1, 1), FI2_GL(1, 1))
            End If
			
			
            Call GATHER (1, MTLOC, MLOC, MGL, KBM1, MYID, NPROCS, NMAP, &
