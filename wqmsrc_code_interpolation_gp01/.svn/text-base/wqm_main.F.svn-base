     !                 & APRSZLZ, AGSZ, AGLZ, ADOCSZ, APOCSZ, ADOCLZ, APOCLZ, &
     !                 & ANH4SZ, ADONSZ, APONSZ, ANH4LZ, ADONLZ, APONLZ, &
     !                 & APO4SZ, ADOPSZ, APOPSZ, APO4LZ, ADOPLZ, APOPLZ, &
     !                 & APRSZ, APRLZ
     !                  Write (KFL) AB1SZ, AB2SZ, AB3SZ, AB1LZ, AB2LZ, AB3LZ, &
     !                 & ADOSZ, ADOLZ, ASASZ, ASUSZ, ASALZ, ASULZ
     !!
