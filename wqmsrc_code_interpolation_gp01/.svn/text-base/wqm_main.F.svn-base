                      !                  CH42_GL(NstationNum_GL(I)),                    &        !'CH4(2)'            gO2/m^3       
                      !                  HS1_GL(NstationNum_GL(I)),                    &        !'HS(1)'            gO2/m^3         
                      !                  HS2_GL(NstationNum_GL(I)),                    &        !'HS(2)'            gO2/m^3         
